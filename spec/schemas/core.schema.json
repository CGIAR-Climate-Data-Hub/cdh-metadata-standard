{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/cdh-metadata-standard/v0.1.0/schemas/core.schema.json",
  "$defs": {
    "additionalAsset": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "file_size": {
          "description": "File size in bytes (integer) or a human-readable string (e.g. 1.2 GB).",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "locations": {
          "description": "Access paths to the same content; the first is canonical.",
          "items": {
            "$ref": "#/$defs/location"
          },
          "minItems": 1,
          "type": "array"
        },
        "media_type": {
          "$ref": "#/$defs/mediaType"
        },
        "name": {
          "type": "string"
        },
        "roles": {
          "description": "Asset roles, e.g. metadata, thumbnail, or describedby.",
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "locations"
      ],
      "type": "object"
    },
    "contact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "name": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          },
          "then": {
            "properties": {
              "organization": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "organization"
            ],
            "type": "object"
          }
        }
      ],
      "anyOf": [
        {
          "properties": {
            "organization": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "organization"
          ],
          "type": "object"
        },
        {
          "properties": {
            "name": {
              "const": ""
            },
            "organization": {
              "const": ""
            }
          },
          "required": [
            "name",
            "organization"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "email": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "format": "email",
              "type": "string"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "roles": {
          "description": "Roles this contact holds (one or more).",
          "type": "array",
          "items": {
            "enum": [
              "licensor",
              "producer",
              "processor",
              "point-of-contact"
            ]
          },
          "uniqueItems": true
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "required": [
        "roles"
      ],
      "type": "object"
    },
    "dataAsset": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "file_size": {
          "description": "File size in bytes (integer) or a human-readable string (e.g. 1.2 GB).",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "locations": {
          "description": "Access paths to the same content; the first is canonical.",
          "items": {
            "$ref": "#/$defs/location"
          },
          "minItems": 1,
          "type": "array"
        },
        "media_type": {
          "$ref": "#/$defs/mediaType"
        },
        "name": {
          "type": "string"
        },
        "href_template": {
          "type": "string",
          "description": "Optional. When present, each locations[].url is treated as a base path and this relative pattern is appended to it (base + filled template). Tokens in {braces} must match a dimensions[].name; the encoder expands the cross-product of those dimensions' values into one item per combination, using locations[0] for the canonical href and any other locations as alternates. When absent, locations[].url are full file URLs and the entry is a single asset.",
          "examples": [
            "mapspam_{crop}_{technology}_{variable}.tif"
          ]
        },
        "nodata": {
          "description": "No-data / fill value for the asset.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "processing_steps": {
          "description": "ids of processing[] steps that produced this asset.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "locations"
      ],
      "type": "object"
    },
    "bboxCoords": {
      "description": "A single bounding box: 2D [west, south, east, north], or 3D [west, south, min_z, east, north, max_z]. WGS84 (EPSG:4326); elevation in metres.",
      "oneOf": [
        {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "prefixItems": [
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            }
          ],
          "items": false
        },
        {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            {
              "type": "number"
            },
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            {
              "type": "number"
            }
          ],
          "items": false
        }
      ]
    },
    "dateOrBlank": {
      "description": "Date or date-time. Use YYYY-MM-DD (e.g. 2026-06-23) or an RFC 3339 date-time (e.g. 2026-06-23T00:00:00Z). May be left blank.",
      "examples": [
        "2026-06-23",
        "2026-06-23T00:00:00Z"
      ],
      "anyOf": [
        {
          "const": ""
        },
        {
          "type": "null"
        },
        {
          "format": "date",
          "type": "string"
        },
        {
          "format": "date-time",
          "type": "string"
        }
      ]
    },
    "doi": {
      "description": "Bare DOI (not a URL).",
      "oneOf": [
        {
          "const": ""
        },
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^10\\.\\d{2,}(\\.\\d+)*/\\S+$"
        }
      ],
      "examples": [
        "10.7910/DVN/SWPENT"
      ]
    },
    "id": {
      "description": "Short, stable, URL-safe identifier (lowercase letters, digits, hyphens).",
      "oneOf": [
        {
          "const": ""
        },
        {
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        }
      ]
    },
    "link": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "rel": {
          "type": "string",
          "description": "Link relation type, e.g. cite-as or describedby."
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "location": {
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Optional access label, e.g. HTTPS or S3."
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    },
    "mediaType": {
      "description": "Media type (IANA), optionally with format parameters such as profile or version.",
      "oneOf": [
        {
          "const": ""
        },
        {
          "pattern": "^[A-Za-z0-9!#$&^_.+-]+/[A-Za-z0-9!#$&^_.+-]+(\\s*;\\s*[^;=]+=[^;]+)*$",
          "type": "string"
        }
      ],
      "examples": [
        "image/tiff; application=geotiff; profile=cloud-optimized",
        "image/tiff; application=geotiff",
        "application/vnd.zarr; version=3",
        "application/netcdf",
        "application/vnd.apache.parquet",
        "application/geopackage+sqlite3",
        "application/json",
        "text/csv"
      ]
    },
    "nameUrl": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "numberOrStringOrNull": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "processingStep": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "additionalProperties": false,
          "description": "Software or code that produced this step's output. Omit when none is published.",
          "properties": {
            "url": {
              "$ref": "#/$defs/nullableString",
              "description": "Link to the production code or repository."
            },
            "version": {
              "$ref": "#/$defs/nullableString",
              "description": "Version, tag, or commit of the code."
            }
          },
          "type": "object"
        },
        "date": {
          "$ref": "#/$defs/dateOrBlank"
        },
        "derived_from": {
          "description": "Upstream sources this step derived from - the data (e.g. a Zenodo/Dataverse landing page), not code.",
          "items": {
            "additionalProperties": false,
            "properties": {
              "title": {
                "$ref": "#/$defs/nullableString"
              },
              "url": {
                "$ref": "#/$defs/nullableString"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "description": {
          "$ref": "#/$defs/nullableString",
          "description": "What this step did."
        },
        "id": {
          "$ref": "#/$defs/nullableString",
          "description": "Step identifier; one step must use id: source for the original generation."
        }
      },
      "type": "object"
    },
    "citation": {
      "additionalProperties": false,
      "description": "Structured citation for the resource.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Cite-as title; may differ from the record's top-level title."
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Names in citation order."
        },
        "date": {
          "$ref": "#/$defs/nullableString",
          "description": "Publication date or year, e.g. 2024 or 2024-07-15.",
          "examples": [
            "2024",
            "2024-07-15"
          ]
        },
        "publisher": {
          "$ref": "#/$defs/nullableString",
          "description": "Publisher or venue: the data publisher/repository for datasets, or the journal for articles."
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "required": [
        "authors",
        "date"
      ],
      "type": "object"
    },
    "publication": {
      "additionalProperties": false,
      "properties": {
        "citation": {
          "$ref": "#/$defs/citation"
        },
        "doi": {
          "$ref": "#/$defs/doi"
        }
      },
      "type": "object"
    },
    "spatialResolution": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/nullableString",
          "description": "Human-readable resolution, e.g. 5 arc-minutes or Kenya counties."
        },
        "note": {
          "$ref": "#/$defs/nullableString",
          "description": "Short spatial interpretation note."
        },
        "reference_system": {
          "$ref": "#/$defs/nullableString",
          "description": "For point/polygon types, the system defining the reporting units (e.g. GAUL 2015, GADM)."
        },
        "type": {
          "description": "Resolution type: xy (regular grid), x, y, point, or polygon.",
          "oneOf": [
            {
              "const": ""
            },
            {
              "enum": [
                "xy",
                "x",
                "y",
                "point",
                "polygon"
              ]
            }
          ]
        },
        "unit": {
          "$ref": "#/$defs/nullableString",
          "description": "Unit of measurement, preferably compliant with UDUNITS-2 or UCUM. Non-grid spatial units may use clear labels such as admin-level."
        },
        "value": {
          "$ref": "#/$defs/numberOrStringOrNull",
          "description": "Numeric resolution value (grid spacing, or admin level)."
        }
      },
      "type": "object"
    },
    "spatial": {
      "additionalProperties": false,
      "properties": {
        "bbox": {
          "description": "Spatial extent. A single bounding box, or an array of boxes when sub-regions are needed (the first is the overall extent; add more only when their union would otherwise leave a large uncovered area). 2D = [west, south, east, north] = [xmin, ymin, xmax, ymax]; 3D = [west, south, min_z, east, north, max_z]. WGS84 (EPSG:4326); elevation in metres. Empty array means unspecified.",
          "oneOf": [
            {
              "$ref": "#/$defs/bboxCoords"
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/bboxCoords"
              }
            }
          ],
          "examples": [
            [-180, -90, 180, 90],
            [
              [-180, -90, 180, 90]
            ]
          ]
        },
        "crs": {
          "$ref": "#/$defs/nullableString",
          "description": "Coordinate reference system of the data: EPSG code, CRS URI, or PROJ string.",
          "examples": [
            "EPSG:4326"
          ]
        },
        "geography": {
          "description": "Named places for discovery (vocab/geography.json ids, UN M49).",
          "items": {
            "$ref": "vocab/geography.schema.json"
          },
          "type": "array",
          "uniqueItems": true
        },
        "geometry_column": {
          "$ref": "#/$defs/nullableString",
          "description": "Name of the geometry column, for vector tables."
        },
        "resolution": {
          "description": "Spatial resolution / spacing entries.",
          "items": {
            "$ref": "#/$defs/spatialResolution"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "temporalResolution": {
      "additionalProperties": false,
      "properties": {
        "note": {
          "$ref": "#/$defs/nullableString",
          "description": "Time-specific interpretation note, e.g. the aggregation method."
        },
        "step": {
          "$ref": "#/$defs/nullableString",
          "description": "ISO 8601 duration of one step.",
          "examples": [
            "P1D",
            "P1M"
          ]
        },
        "unit": {
          "$ref": "#/$defs/nullableString",
          "description": "Time unit of the data, e.g. daily or monthly."
        },
        "values": {
          "description": "Named or easily interpretable values, e.g. 1-12 for months.",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "temporal": {
      "additionalProperties": false,
      "properties": {
        "end_date": {
          "$ref": "#/$defs/dateOrBlank",
          "examples": [
            "2020-01-01"
          ]
        },
        "resolution": {
          "$ref": "#/$defs/temporalResolution"
        },
        "start_date": {
          "$ref": "#/$defs/dateOrBlank",
          "examples": [
            "2020-01-01"
          ]
        }
      },
      "type": "object"
    }
  },
  "description": "JSON Schema for validating CDH metadata input YAML records before serialization to STAC or OGC API Records. This validates structure, types, controlled values, and basic input rules; CDH review still handles contextual and curatorial checks.",
  "properties": {
    "additional_assets": {
      "description": "Sidecar or auxiliary assets, e.g. metadata files or thumbnails.",
      "items": {
        "$ref": "#/$defs/additionalAsset"
      },
      "type": "array"
    },
    "additional_links": {
      "description": "Related links: citation targets, services, or related resources.",
      "items": {
        "$ref": "#/$defs/link"
      },
      "type": "array"
    },
    "cdh_schema_version": {
      "type": "string",
      "description": "CDH standard version this record targets. Matches the release tag: v<MAJOR>.<MINOR>.<PATCH>.",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "citation": {
      "$ref": "#/$defs/citation"
    },
    "contact": {
      "items": {
        "$ref": "#/$defs/contact"
      },
      "minItems": 1,
      "contains": {
        "type": "object",
        "properties": {
          "roles": {
            "contains": {
              "const": "licensor"
            }
          }
        },
        "required": [
          "roles"
        ]
      },
      "type": "array"
    },
    "created": {
      "$ref": "#/$defs/dateOrBlank",
      "description": "Date the record was first published to the Hub - the metadata record, not the data file. May be left blank in drafts; populated during CDH review."
    },
    "data": {
      "description": "Data assets for the resource; at least one entry.",
      "items": {
        "$ref": "#/$defs/dataAsset"
      },
      "minItems": 1,
      "type": "array"
    },
    "description": {
      "type": "string",
      "description": "Canonical human- and AI-readable summary of the resource."
    },
    "doi": {
      "$ref": "#/$defs/doi"
    },
    "extensions": {
      "description": "Pinned URLs of the CDH extension schemas this record uses.",
      "items": {
        "format": "uri",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "funding": {
      "description": "Funding sources for the resource.",
      "items": {
        "$ref": "#/$defs/nameUrl"
      },
      "type": "array"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "keywords": {
      "description": "Free-text search terms. Each item is either a plain string, or an object linking the term to an external vocabulary/ontology (e.g., AGROVOC, GEMET). Linked-keyword items are also emitted as ontology themes in the serialized output, grouped by `scheme`.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "term"
            ],
            "properties": {
              "term": {
                "type": "string",
                "minLength": 1
              },
              "scheme": {
                "description": "Resolvable URI of the controlled vocabulary or ontology this term comes from.",
                "type": "string",
                "format": "uri"
              },
              "uri": {
                "description": "Resolvable URI of the specific concept within `scheme`.",
                "type": "string",
                "format": "uri"
              },
              "description": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "license": {
      "type": "string",
      "description": "License of the data. SPDX identifier preferred.",
      "examples": [
        "CC-BY-4.0",
        "CC-BY-SA-4.0",
        "CC0-1.0"
      ]
    },
    "note": {
      "$ref": "#/$defs/nullableString",
      "description": "Caveats, warnings, or interpretation-critical remarks not captured in description."
    },
    "previous_version": {
      "$ref": "#/$defs/nullableString",
      "description": "id of the predecessor record, when this supersedes an earlier version."
    },
    "processing": {
      "description": "Ordered processing/provenance steps; at least one must have id: source.",
      "contains": {
        "properties": {
          "id": {
            "const": "source"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "items": {
        "$ref": "#/$defs/processingStep"
      },
      "minContains": 1,
      "type": "array"
    },
    "related_publications": {
      "description": "Related works such as papers or reports.",
      "items": {
        "$ref": "#/$defs/publication"
      },
      "type": "array"
    },
    "resource_type": {
      "description": "Kind of resource: dataset, document, tool, or ai-skill.",
      "oneOf": [
        {
          "const": ""
        },
        {
          "$ref": "vocab/resource_type.schema.json"
        }
      ]
    },
    "spatial": {
      "$ref": "#/$defs/spatial"
    },
    "temporal": {
      "$ref": "#/$defs/temporal"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title of the resource."
    },
    "updated": {
      "$ref": "#/$defs/dateOrBlank",
      "description": "Date the record was last revised - the metadata record, not the data file. May be left blank in drafts; populated during CDH review."
    },
    "version": {
      "$ref": "#/$defs/nullableString",
      "description": "Version of the resource, when versioned.",
      "examples": [
        "v1.0",
        "2.0-release-2"
      ]
    }
  },
  "required": [
    "cdh_schema_version",
    "id",
    "title",
    "description",
    "license",
    "resource_type",
    "keywords",
    "contact",
    "created",
    "updated",
    "data"
  ],
  "anyOf": [
    {
      "required": [
        "citation"
      ]
    },
    {
      "properties": {
        "doi": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "doi"
      ]
    }
  ],
  "title": "Climate Data Hub Metadata Input Schema",
  "type": "object"
}
