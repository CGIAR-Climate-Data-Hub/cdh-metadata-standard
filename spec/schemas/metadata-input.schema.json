{
  "$id": "https://cgiar.org/cdh/schemas/metadata-input.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$defs": {
    "additionalAsset": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "file_size": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "media_type": {
          "$ref": "#/$defs/mediaType"
        },
        "name": {
          "type": "string"
        },
        "roles": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "cdh": {
      "additionalProperties": false,
      "properties": {
        "climate": {
          "$ref": "#/$defs/climate"
        },
        "commodities": {
          "items": {
            "$ref": "vocab/commodity.schema.json"
          },
          "type": "array",
          "uniqueItems": true
        },
        "domain": {
          "items": {
            "$ref": "vocab/domain.schema.json"
          },
          "type": "array",
          "uniqueItems": true
        },
        "not_recommended_for": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "reason": {
                "type": "string"
              },
              "use": {
                "type": "string"
              },
              "use_instead": {
                "$ref": "#/$defs/nullableString"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "use_cases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "classSet": {
      "additionalProperties": false,
      "properties": {
        "values": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "value": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "variable": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "climate": {
      "additionalProperties": false,
      "properties": {
        "baseline": {
          "additionalProperties": false,
          "properties": {
            "end_date": {
              "$ref": "#/$defs/dateOrBlank"
            },
            "start_date": {
              "$ref": "#/$defs/dateOrBlank"
            }
          },
          "type": "object"
        },
        "bias_adjustment": {
          "additionalProperties": false,
          "properties": {
            "method": {
              "$ref": "#/$defs/nullableString"
            },
            "reference_dataset": {
              "$ref": "#/$defs/nullableString"
            }
          },
          "type": "object"
        },
        "downscaling": {
          "additionalProperties": false,
          "properties": {
            "method": {
              "$ref": "#/$defs/nullableString"
            },
            "resolution": {
              "$ref": "#/$defs/numberOrStringOrNull"
            }
          },
          "type": "object"
        },
        "hazards": {
          "items": {
            "$ref": "vocab/hazard.schema.json"
          },
          "type": "array",
          "uniqueItems": true
        },
        "mip_era": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "enum": [
                "CMIP5",
                "CMIP6"
              ]
            }
          ]
        },
        "models": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "scenarios": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "type": "object"
    },
    "contact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "name": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          },
          "then": {
            "properties": {
              "organization": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "organization"
            ],
            "type": "object"
          }
        }
      ],
      "anyOf": [
        {
          "properties": {
            "organization": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "organization"
          ],
          "type": "object"
        },
        {
          "properties": {
            "name": {
              "const": ""
            },
            "organization": {
              "const": ""
            }
          },
          "required": [
            "name",
            "organization"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "email": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "format": "email",
              "type": "string"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "role": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "enum": [
                "licensor",
                "producer",
                "processor",
                "host"
              ]
            }
          ]
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "required": [
        "role"
      ],
      "type": "object"
    },
    "dataAsset": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "file_size": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "media_type": {
          "$ref": "#/$defs/mediaType"
        },
        "name": {
          "type": "string"
        },
        "nodata": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "processing_steps": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "dateOrBlank": {
      "anyOf": [
        {
          "const": ""
        },
        {
          "type": "null"
        },
        {
          "format": "date",
          "type": "string"
        },
        {
          "format": "date-time",
          "type": "string"
        }
      ]
    },
    "dimension": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "reference_system": {
          "$ref": "#/$defs/nullableString"
        },
        "type": {
          "type": "string"
        },
        "values": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "geography": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/nullableString"
        },
        "spatial_join": {
          "additionalProperties": false,
          "properties": {
            "note": {
              "$ref": "#/$defs/nullableString"
            },
            "source_key": {
              "$ref": "#/$defs/nullableString"
            },
            "target": {
              "additionalProperties": false,
              "properties": {
                "id": {
                  "$ref": "#/$defs/nullableString"
                },
                "key": {
                  "$ref": "#/$defs/nullableString"
                },
                "url": {
                  "$ref": "#/$defs/nullableString"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "id": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        }
      ]
    },
    "link": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "rel": {
          "type": "string"
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "mediaType": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "pattern": "^[A-Za-z0-9!#$&^_.+-]+/[A-Za-z0-9!#$&^_.+-]+(\\s*;\\s*[^;=]+=[^;]+)*$",
          "type": "string"
        }
      ]
    },
    "nameUrl": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "numberOrStringOrNull": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "processingStep": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "additionalProperties": false,
          "properties": {
            "url": {
              "$ref": "#/$defs/nullableString"
            },
            "version": {
              "$ref": "#/$defs/nullableString"
            }
          },
          "type": "object"
        },
        "date": {
          "$ref": "#/$defs/dateOrBlank"
        },
        "derived_from": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "title": {
                "$ref": "#/$defs/nullableString"
              },
              "url": {
                "$ref": "#/$defs/nullableString"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "description": {
          "$ref": "#/$defs/nullableString"
        },
        "id": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "publication": {
      "additionalProperties": false,
      "properties": {
        "citation": {
          "type": "string"
        },
        "doi": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    },
    "resolution": {
      "additionalProperties": false,
      "properties": {
        "aggregation": {
          "$ref": "#/$defs/nullableString"
        },
        "label": {
          "$ref": "#/$defs/nullableString"
        },
        "unit": {
          "$ref": "#/$defs/nullableString"
        },
        "value": {
          "$ref": "#/$defs/numberOrStringOrNull"
        }
      },
      "type": "object"
    },
    "spatial": {
      "additionalProperties": false,
      "properties": {
        "bbox": {
          "description": "Spatial extent. STAC-aligned: an array of one or more bounding boxes, each of length 2*n where n is the number of dimensions. Order is all axes of the southwesterly-most extent, followed by all axes of the northeasterly-most extent. So 2D = [west, south, east, north] = [xmin, ymin, xmax, ymax]; 3D = [west, south, min_z, east, north, max_z] = [xmin, ymin, zmin, xmax, ymax, zmax]. Coordinates are WGS84 (EPSG:4326); elevation is in metres. The first entry is the overall spatial extent; additional entries describe sub-regions (use only when their union would otherwise leave a large uncovered area). Empty outer array means unspecified.",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "prefixItems": [
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 },
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 }
                ],
                "items": false
              },
              {
                "type": "array",
                "minItems": 6,
                "maxItems": 6,
                "prefixItems": [
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 },
                  { "type": "number" },
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 },
                  { "type": "number" }
                ],
                "items": false
              }
            ]
          }
        },
        "crs": {
          "$ref": "#/$defs/nullableString"
        },
        "geography": {
          "$ref": "#/$defs/nullableString"
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        }
      },
      "type": "object"
    },
    "temporal": {
      "additionalProperties": false,
      "properties": {
        "end_date": {
          "$ref": "#/$defs/dateOrBlank"
        },
        "resolution": {
          "$ref": "#/$defs/resolution"
        },
        "start_date": {
          "$ref": "#/$defs/dateOrBlank"
        }
      },
      "type": "object"
    },
    "variable": {
      "additionalProperties": false,
      "properties": {
        "aggregation": {
          "additionalProperties": false,
          "properties": {
            "method": {
              "$ref": "#/$defs/nullableString"
            },
            "notes": {
              "$ref": "#/$defs/nullableString"
            },
            "weight_by": {
              "$ref": "#/$defs/nullableString"
            }
          },
          "type": "object"
        },
        "data_type": {
          "$ref": "#/$defs/nullableString"
        },
        "description": {
          "type": "string"
        },
        "dimensions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "note": {
          "$ref": "#/$defs/nullableString"
        },
        "unit": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "type": "object"
    }
  },
  "description": "JSON Schema for validating CDH metadata input YAML records before serialization to STAC or OGC API Records. This validates structure, types, controlled values, and basic input rules; CDH review still handles contextual and curatorial checks.",
  "properties": {
    "additional_assets": {
      "items": {
        "$ref": "#/$defs/additionalAsset"
      },
      "type": "array"
    },
    "additional_links": {
      "items": {
        "$ref": "#/$defs/link"
      },
      "type": "array"
    },
    "cdh": {
      "$ref": "#/$defs/cdh"
    },
    "cdh_schema_version": {
      "type": "string"
    },
    "citation": {
      "type": "string"
    },
    "classes": {
      "items": {
        "$ref": "#/$defs/classSet"
      },
      "type": "array"
    },
    "contact": {
      "items": {
        "$ref": "#/$defs/contact"
      },
      "type": "array"
    },
    "created": {
      "$ref": "#/$defs/dateOrBlank"
    },
    "data": {
      "items": {
        "$ref": "#/$defs/dataAsset"
      },
      "minItems": 1,
      "type": "array"
    },
    "description": {
      "type": "string"
    },
    "dimensions": {
      "items": {
        "$ref": "#/$defs/dimension"
      },
      "type": "array"
    },
    "doi": {
      "$ref": "#/$defs/nullableString"
    },
    "encoding": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "enum": [
            "stac",
            "ogc-records"
          ]
        }
      ]
    },
    "funding": {
      "items": {
        "$ref": "#/$defs/nameUrl"
      },
      "type": "array"
    },
    "geography": {
      "$ref": "#/$defs/geography"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "keywords": {
      "description": "Free-text search terms. Each item is either a plain string, or an object linking the term to an external vocabulary/ontology (e.g., AGROVOC, GEMET). Linked-keyword items are also emitted as ontology themes in the serialized output, grouped by `scheme`.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["term"],
            "properties": {
              "term": { "type": "string", "minLength": 1 },
              "scheme": {
                "description": "Resolvable URI of the controlled vocabulary or ontology this term comes from.",
                "type": "string",
                "format": "uri"
              },
              "uri": {
                "description": "Resolvable URI of the specific concept within `scheme`.",
                "type": "string",
                "format": "uri"
              },
              "description": { "type": "string" }
            }
          }
        ]
      }
    },
    "license": {
      "type": "string"
    },
    "license_holder": {
      "type": "string"
    },
    "note": {
      "$ref": "#/$defs/nullableString"
    },
    "previous_version": {
      "$ref": "#/$defs/nullableString"
    },
    "processing": {
      "items": {
        "$ref": "#/$defs/processingStep"
      },
      "type": "array"
    },
    "related_publications": {
      "items": {
        "$ref": "#/$defs/publication"
      },
      "type": "array"
    },
    "resource_type": {
      "oneOf": [
        {
          "const": ""
        },
        {
          "enum": [
            "dataset",
            "document",
            "model",
            "notebook",
            "code",
            "service",
            "dashboard",
            "api",
            "method",
            "knowledge-product"
          ]
        }
      ]
    },
    "spatial": {
      "$ref": "#/$defs/spatial"
    },
    "temporal": {
      "$ref": "#/$defs/temporal"
    },
    "title": {
      "type": "string"
    },
    "updated": {
      "$ref": "#/$defs/dateOrBlank"
    },
    "variables": {
      "items": {
        "$ref": "#/$defs/variable"
      },
      "type": "array"
    },
    "version": {
      "$ref": "#/$defs/nullableString"
    }
  },
  "required": [
    "cdh_schema_version",
    "encoding",
    "id",
    "title",
    "description",
    "license",
    "resource_type",
    "keywords",
    "license_holder",
    "contact",
    "citation",
    "created",
    "updated",
    "cdh",
    "data"
  ],
  "title": "Climate Data Hub Metadata Input Schema",
  "type": "object"
}
