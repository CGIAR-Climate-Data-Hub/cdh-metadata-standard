{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/cdh-metadata-standard/v0.1.0/schemas/vocab/vocabulary.schema.json",
  "title": "CDH Vocabulary File Schema",
  "description": "Validates the JSON source files in vocab/.",
  "type": "object",
  "additionalProperties": false,
  "required": ["scheme", "concepts"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "scheme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "source_scheme"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_scheme": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "uri", "title"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "uri": {
              "type": "string",
              "format": "uri"
            },
            "title": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "code", "uri"],
        "allOf": [
          {
            "if": {
              "properties": {
                "uri": {
                  "const": null
                }
              },
              "required": ["uri"]
            },
            "then": {
              "required": ["description"],
              "properties": {
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "uri": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "format": "uri"
              }
            ]
          },
          "broader": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/id"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    }
  }
}
