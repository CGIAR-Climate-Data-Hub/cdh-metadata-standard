{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/cdh-metadata-standard/v0.0.3/extensions/cdh/schema.json",
  "title": "CDH Extension",
  "description": "CGIAR Climate Data Hub governance fields.",
  "type": "object",
  "properties": {
    "cdh": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain"],
      "properties": {
        "domain": {
          "description": "CDH domain(s); closed vocabulary (vocab/domain.json). Drives catalog browse and filtering.",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "../../schemas/vocab/domain.schema.json" }
        },
        "use_cases": {
          "description": "Short statements of what the data is well suited for.",
          "type": "array",
          "items": { "type": "string" }
        },
        "not_recommended_for": {
          "description": "Uses to avoid, each with a reason and optional alternative.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "reason": { "type": "string", "description": "Why this use is discouraged." },
              "use": { "type": "string", "description": "The use being discouraged." },
              "use_instead": { "type": ["string", "null"], "description": "Recommended alternative, if any." }
            }
          }
        }
      }
    }
  }
}
