{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/cdh-metadata-standard/v0.0.3/extensions/classification/schema.json",
  "title": "Classification Extension",
  "description": "Class definitions for categorical / classified variables.",
  "type": "object",
  "properties": {
    "classes": {
      "description": "Class definitions for categorical variables; each entry maps to a variable.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "variable": { "type": "string", "description": "Name of the variable these classes apply to." },
          "values": {
            "description": "The class values for the variable.",
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "description": "Human-readable class label." },
                "description": { "type": "string", "description": "What this class means." },
                "value": {
                  "description": "The coded value as stored in the data.",
                  "anyOf": [
                    { "type": "string" },
                    { "type": "number" },
                    { "type": "boolean" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
