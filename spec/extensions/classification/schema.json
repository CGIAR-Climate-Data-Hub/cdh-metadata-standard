{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/metadata/v0.0.2/extensions/classification/schema.json",
  "title": "Classification Extension",
  "description": "Class definitions for categorical / classified variables.",
  "type": "object",
  "properties": {
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "variable": { "type": "string" },
          "values": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "description": { "type": "string" },
                "value": {
                  "anyOf": [
                    { "type": "string" },
                    { "type": "number" },
                    { "type": "boolean" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
