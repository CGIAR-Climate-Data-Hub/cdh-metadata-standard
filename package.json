{
  "name": "cgiar-cdh-metadata",
  "version": "0.0.1",
  "private": true,
  "description": "Climate Data Hub metadata standard, input schema, and controlled vocabularies.",
  "type": "module",
  "scripts": {
    "test": "npm run check-markdown && npm run check",
    "check": "npm run check-schemas && npm run check-vocabs && npm run compile-schemas && npm run check-yaml",
    "build-geography": "node scripts/build-geography-vocab.js",
    "gen-schemas": "node scripts/generate-vocab-schemas.js",
    "check-schemas": "node scripts/generate-vocab-schemas.js --check",
    "check-vocabs": "node scripts/check-vocabs.js",
    "compile-schemas": "node scripts/compile-schemas.js",
    "check-yaml": "node scripts/validate-yaml.js",
    "check-markdown": "remark . -f -r .github/remark.yaml",
    "format-markdown": "remark . -o -r .github/remark.yaml"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "remark-cli": "^12.0.0",
    "remark-gfm": "^4.0.0",
    "remark-lint": "^9.1.2",
    "remark-lint-no-html": "^3.1.2",
    "remark-preset-lint-consistent": "^5.1.2",
    "remark-preset-lint-markdown-style-guide": "^5.1.3",
    "remark-preset-lint-recommended": "^6.1.3",
    "remark-validate-links": "^13.0.0"
  }
}
