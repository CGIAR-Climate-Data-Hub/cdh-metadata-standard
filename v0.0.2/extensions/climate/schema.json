{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/metadata/v0.0.2/extensions/climate/schema.json",
  "title": "Climate Extension",
  "description": "Climate projection provenance: baseline, bias adjustment, downscaling, scenarios.",
  "type": "object",
  "$defs": {
    "nullableString": { "type": ["string", "null"] },
    "dateOrBlank": {
      "anyOf": [
        { "const": "" },
        { "type": "null" },
        { "type": "string", "format": "date" },
        { "type": "string", "format": "date-time" }
      ]
    },
    "numberOrStringOrNull": {
      "anyOf": [{ "type": "number" }, { "type": "string" }, { "type": "null" }]
    }
  },
  "properties": {
    "climate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseline": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start_date": { "$ref": "#/$defs/dateOrBlank" },
            "end_date": { "$ref": "#/$defs/dateOrBlank" }
          }
        },
        "bias_adjustment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "method": { "$ref": "#/$defs/nullableString" },
            "reference_dataset": { "$ref": "#/$defs/nullableString" }
          }
        },
        "downscaling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "method": { "$ref": "#/$defs/nullableString" },
            "resolution": { "$ref": "#/$defs/numberOrStringOrNull" }
          }
        },
        "mip_era": {
          "oneOf": [{ "const": "" }, { "enum": ["CMIP5", "CMIP6"] }]
        },
        "models": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "scenarios": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    }
  }
}
