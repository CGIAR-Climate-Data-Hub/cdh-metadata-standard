{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgiar-climate-data-hub.github.io/cdh-metadata-standard/v0.0.2/extensions/cdh/schema.json",
  "title": "CDH Extension",
  "description": "CGIAR Climate Data Hub governance fields.",
  "type": "object",
  "properties": {
    "cdh": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain"],
      "properties": {
        "domain": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "../../schemas/vocab/domain.schema.json" }
        },
        "use_cases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "not_recommended_for": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "reason": { "type": "string" },
              "use": { "type": "string" },
              "use_instead": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
